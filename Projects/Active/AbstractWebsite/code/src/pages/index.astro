---
// Main Index Page — Demonstrates all Hero patterns and components
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Card from '../components/Card.astro';
import SectionDivider from '../components/SectionDivider.astro';
import DataStream from '../components/DataStream.astro';
import ScrollReveal from '../components/ScrollReveal.astro';
---

<BaseLayout title="NOISE WEB — Digital Ruins Exhibition" navVariant="transparent">
  <!-- PATTERN A: COLLAGE HERO -->
  <Hero
    pattern="collage"
    title="DIGITAL RUINS"
    subtitle="EXHIBITION 01"
    description="A world where memory and technology decay together. Not loud cyberpunk, but quiet melancholy. Every pixel carries history. Every texture tells of age. The interface is a palimpsest: digital layers over analog remnants."
    ctaText="ENTER EXHIBITION"
    ctaHref="#exhibition"
    imageSrc="https://images.unsplash.com/photo-1635070041078-e363dbe005cb?w=1920&q=80"
    imageAlt="Abstract digital jellyfish texture in cyan and deep blue"
  />

  <!-- SECTION: EXHIBITION OVERVIEW -->
  <section id="exhibition" class="section" aria-labelledby="exhibition-title">
    <ScrollReveal delay={0.1}>
      <SectionDivider label="EXHIBITION" position="left" />
    </ScrollReveal>

    <div class="container">
      <ScrollReveal delay={0.2}>
        <h2 id="exhibition-title" class="section-heading">CURATED SECTIONS</h2>
      </ScrollReveal>

      <ScrollReveal delay={0.3}>
        <p class="poetic-text" style="margin-top: var(--space-6); max-width: 55ch;">
          Five distinct compositional patterns derived from fourteen reference images spanning album art, glitch aesthetics, collage photography, typographic art, concert posters, and generative code art. Each section is a framed composition — a poster, a cover, a moment suspended in digital amber.
        </p>
      </ScrollReveal>

      <!-- CARD GRID - STAGGERED -->
      <div class="card-grid-stagger" style="margin-top: var(--space-10);" role="list">
        <ScrollReveal delay={0.4}>
          <article class="card card-stack reveal" role="listitem">
            <div class="card-image">
              <img src="https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=800&q=80" alt="Abstract eye closeup - organic form" class="card-image-treatment" loading="lazy" />
            </div>
            <div class="card-content">
              <span class="card-badge">PATTERN A</span>
              <h3 class="card-title">FULL-SCREEN COLLAGE</h3>
              <p class="card-body">Atmospheric full-viewport entry combining background imagery with layered text blocks. 60/40 asymmetric split derived from vertical stacking compositions.</p>
            </div>
          </article>
        </ScrollReveal>

        <ScrollReveal delay={0.5}>
          <article class="card card-stack reveal" role="listitem">
            <div class="card-image">
              <img src="https://images.unsplash.com/photo-1635070041078-e363dbe005cb?w=800&q=80" alt="Jellyfish-like digital form" class="card-image-treatment" loading="lazy" />
            </div>
            <div class="card-content">
              <span class="card-badge">PATTERN B</span>
              <h3 class="card-title">DIAGONAL SPLIT</h3>
              <p class="card-body">Dramatic diagonal division creating tension between dark and light zones. Derived from album art with semi-transparent text overlays and zone-based color temperature.</p>
            </div>
          </article>
        </ScrollReveal>

        <ScrollReveal delay={0.6}>
          <article class="card card-stack reveal" role="listitem">
            <div class="card-image">
              <img src="https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=800&q=80" alt="Fractal mandelbrot visualization" class="card-image-treatment" loading="lazy" />
            </div>
            <div class="card-content">
              <span class="card-badge">PATTERN C</span>
              <h3 class="card-title">SPLIT-SCREEN CODE</h3>
              <p class="card-body">Educational/technical sections showing code alongside visual output. Monospace authenticity with CRT scanline overlay on code panel only. 1fr/2fr split.</p>
            </div>
          </article>
        </ScrollReveal>

        <ScrollReveal delay={0.7}>
          <article class="card card-stack reveal" role="listitem">
            <div class="card-image">
              <div class="paper-texture" style="height: 100%; background: var(--color-bg-parchment);" aria-hidden="true"></div>
            </div>
            <div class="card-content">
              <span class="card-badge">PATTERN D</span>
              <h3 class="card-title">TYPOGRAPHIC COMPOSITION</h3>
              <p class="card-body">Minimalist type-as-art hero. Bold sans-serif kinetic typography with teal blur shapes, paper fold texture, and archival marginalia. For manifestos and poetic content.</p>
            </div>
          </article>
        </ScrollReveal>

        <ScrollReveal delay={0.8}>
          <article class="card card-stack reveal" role="listitem">
            <div class="card-image">
              <img src="https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=800&q=80" alt="Vertical stack of three abstract forms" class="card-image-treatment" loading="lazy" />
            </div>
            <div class="card-content">
              <span class="card-badge">PATTERN E</span>
              <h3 class="card-title">VERTICAL STACK</h3>
              <p class="card-body">Rhythmic repeating visual elements creating meditative vertical composition. Three stacked items with tight gaps, text block opposite. Derived from triple-eye composition.</p>
            </div>
          </article>
        </ScrollReveal>
      </div>
    </div>
  </section>

  <!-- SECTION: DESIGN SYSTEM TOKENS -->
  <section class="section" aria-labelledby="tokens-title">
    <ScrollReveal delay={0.1}>
      <SectionDivider label="DESIGN TOKENS" position="center" />
    </ScrollReveal>

    <div class="container">
      <ScrollReveal delay={0.2}>
        <h2 id="tokens-title" class="section-heading">CORE TOKENS</h2>
      </ScrollReveal>

      <ScrollReveal delay={0.3}>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--gap-lg); margin-top: var(--space-8);">
          <article class="card" style="height: 100%;">
            <div class="card-content">
              <span class="card-badge">COLOR</span>
              <h3 class="card-title">MONOCHROMATIC BLUE</h3>
              <p class="card-body" style="margin-bottom: var(--space-4);">Deep cold navy through muted indigo to cyan-teal accent. Violet-magenta glitch intrusion. Warm parchment for texture layers only.</p>
              <div style="display: flex; gap: var(--space-2); flex-wrap: wrap; margin-top: var(--space-4);">
                <span class="label label-accent">#0a1628</span>
                <span class="label label-accent">#142a4a</span>
                <span class="label label-accent">#a8f0e8</span>
                <span class="label label-accent">#d060c0</span>
              </div>
            </div>
          </article>

          <article class="card" style="height: 100%;">
            <div class="card-content">
              <span class="card-badge">TYPOGRAPHY</span>
              <h3 class="card-title">THREE FAMILIES</h3>
              <p class="card-body" style="margin-bottom: var(--space-4);">Inter (UI), Crimson Text (Display), JetBrains Mono (Data). Playfair Display for poetic text. Inter Tight for labels.</p>
              <div style="display: flex; flex-direction: column; gap: var(--space-2); margin-top: var(--space-4);">
                <span class="code-text" style="font-size: var(--text-xs);">Inter — Body & UI</span>
                <span class="code-text" style="font-size: var(--text-xs); font-family: var(--font-serif);">Crimson Text — Headers</span>
                <span class="code-text" style="font-size: var(--text-xs);">JetBrains Mono — Code</span>
              </div>
            </div>
          </article>

          <article class="card" style="height: 100%;">
            <div class="card-content">
              <span class="card-badge">TEXTURE</span>
              <h3 class="card-title">FIVE LAYERS</h3>
              <p class="card-body" style="margin-bottom: var(--space-4);">Noise (mandatory) → Paper → Scanlines → Chromatic Aberration → Halftone. Max 3 layers combined. Opacity calibrated per context.</p>
              <div style="display: flex; flex-direction: column; gap: var(--space-2); margin-top: var(--space-4); font-size: var(--text-xs);">
                <span class="label">Noise: 3–18% opacity</span>
                <span class="label">Scanlines: 3px repeat</span>
                <span class="label">Chromatic: ±2px offset</span>
                <span class="label">Halftone: 3px dots</span>
              </div>
            </div>
          </article>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- SECTION: SPLIT-SCREEN DEMO -->
  <section class="section" aria-labelledby="split-title">
    <ScrollReveal delay={0.1}>
      <SectionDivider label="SPLIT SCREEN DEMO" position="left" />
    </ScrollReveal>

    <Hero
      pattern="split"
      title="GENERATIVE NOISE FIELD"
      subtitle="PATTERN C — SPLIT SCREEN"
      codeContent={`// Generative noise field — Perlin noise 3D
const noise = new PerlinNoise(Math.random());
const field = new Float32Array(width * height);
const time = performance.now() * 0.001;

for (let y = 0; y < height; y++) {
  for (let x = 0; x < width; x++) {
    const nx = x * 0.01;
    const ny = y * 0.01;
    const n = noise.noise3D(nx, ny, time * 0.1);
    field[y * width + x] = (n + 1) * 0.5; // Normalize 0-1
  }
}

render(field);
requestAnimationFrame(loop);`}
      imageSrc="https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=1920&q=80"
      imageAlt="Generative noise visualization"
    />
  </section>

  <!-- SECTION: DIAGONAL HERO -->
  <section class="section" aria-labelledby="diagonal-title">
    <ScrollReveal delay={0.1}>
      <SectionDivider label="DIAGONAL COMPOSITION" position="right" />
    </ScrollReveal>

    <Hero
      pattern="diagonal"
      title="ASYMMETRY AS ORDER"
      subtitle="PATTERN B — DIAGONAL SPLIT"
      description="Never center-align. Never use symmetric grids. The 60/40 split, the diagonal division, the off-balance composition — these create the editorial, collage-like feel. The website lives in the tension between organic and digital, never fully one nor the other."
      ctaText="EXPLORE PATTERN"
      ctaHref="#"
      imageSrc="https://images.unsplash.com/photo-1635070041078-e363dbe005cb?w=1920&q=80"
      imageAlt="Diagonal split composition with abstract forms"
    />
  </section>

  <!-- SECTION: TYPOGRAPHIC HERO -->
  <section class="section" aria-labelledby="typo-title">
    <Hero
      pattern="typographic"
      title="NOISE WEB"
      subtitle="DIGITAL RUINS"
      ctaText="VIEW MANIFESTO"
      ctaHref="#manifesto"
    />
  </section>

  <!-- SECTION: VERTICAL STACK -->
  <section class="section" aria-labelledby="stack-title">
    <ScrollReveal delay={0.1}>
      <SectionDivider label="VERTICAL STACK" position="left" />
    </ScrollReveal>

    <Hero
      pattern="stack"
      title="RHYTHM IN REPETITION"
      subtitle="PATTERN E — VERTICAL STACK"
      description="Rhythmic, repeating visual elements creating meditative vertical composition. Three stacked items with tight gaps, text block opposite. Derived from triple-eye composition. Each frame is a moment suspended in digital amber."
      ctaText="VIEW ARCHIVE"
      ctaHref="#archive"
      imageSrc="https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=1920&q=80"
      imageAlt="First stack item — abstract digital form"
    />
  </section>

  <!-- SECTION: DATA STREAM -->
  <section id="archive" class="section" aria-labelledby="data-title">
    <ScrollReveal delay={0.1}>
      <SectionDivider label="DATA STREAM" position="center" />
    </ScrollReveal>

    <div class="container">
      <ScrollReveal delay={0.2}>
        <h2 id="data-title" class="section-heading">LIVE DATA FEED</h2>
      </ScrollReveal>

      <ScrollReveal delay={0.3}>
        <DataStream
          title="NOISE_FIELD"
          language="glsl"
          content={`
// Fragment shader — Noise field visualization
#version 300 es
precision highp float;

uniform float u_time;
uniform vec2 u_resolution;
uniform sampler2D u_noise;

out vec4 fragColor;

float hash(vec2 p) {
  return fract(sin(dot(p, vec2(127.1, 311.7))) * 43758.5453);
}

float noise(vec2 p) {
  vec2 i = floor(p);
  vec2 f = fract(p);
  f = f * f * (3.0 - 2.0 * f);

  float a = hash(i);
  float b = hash(i + vec2(1.0, 0.0));
  float c = hash(i + vec2(0.0, 1.0));
  float d = hash(i + vec2(1.0, 1.0));

  return mix(mix(a, b, f.x), mix(c, d, f.x), f.y);
}

float fbm(vec2 p) {
  float value = 0.0;
  float amplitude = 0.5;
  for (int i = 0; i < 6; i++) {
    value += amplitude * noise(p);
    p *= 2.0;
    amplitude *= 0.5;
  }
  return value;
}

void main() {
  vec2 uv = gl_FragCoord.xy / u_resolution.xy;
  vec2 p = uv * 8.0;

  float n = fbm(p + u_time * 0.1);
  n = fbm(p * 2.0 + n * 2.0 + u_time * 0.05); // Domain warping

  vec3 color = mix(
    vec3(0.04, 0.16, 0.29),  // Deep navy
    vec3(0.66, 0.94, 0.91),  // Cyan accent
    smoothstep(0.3, 0.7, n)
  );

  // Scanline effect
  color *= 1.0 - 0.1 * sin(gl_FragCoord.y * 3.0 + u_time * 10.0);

  // Vignette
  float vig = 1.0 - 0.3 * length(uv - 0.5);
  color *= vig;

  fragColor = vec4(color, 1.0);
}
          `}
        />
      </ScrollReveal>
    </div>
  </section>

  <!-- SECTION: MANIFESTO -->
  <section id="manifesto" class="section paper-texture" aria-labelledby="manifesto-title">
    <ScrollReveal delay={0.1}>
      <SectionDivider label="MANIFESTO" position="left" />
    </ScrollReveal>

    <div class="container" style="max-width: 800px;">
      <ScrollReveal delay={0.2}>
        <h2 id="manifesto-title" class="section-heading">DESIGN PHILOSOPHY</h2>
      </ScrollReveal>

      <ScrollReveal delay={0.3}>
        <div class="poetic-text" style="margin-top: var(--space-8);">
          <p style="margin-bottom: var(--space-6);">
            <strong>Texture Before Color.</strong> The palette is intentionally narrow. Visual richness comes from grain, noise, scanlines, halftones, chromatic aberration, and paper texture — not from chromatic variety.
          </p>
          <p style="margin-bottom: var(--space-6);">
            <strong>Imperfection as Identity.</strong> Glitches, pixelation, compression artifacts, misalignment, and distortion are not bugs. They are the visual signature. Every element should feel slightly aged, slightly broken.
          </p>
          <p style="margin-bottom: var(--space-6);">
            <strong>Asymmetry as Order.</strong> Never center-align. Never use symmetric grids. The 60/40 split, the diagonal division, the off-balance composition — these create the editorial, collage-like feel.
          </p>
          <p style="margin-bottom: var(--space-6);">
            <strong>Typography as Material.</strong> Text is not just content. It is texture, shape, pattern, and atmosphere. Fragmented words, broken serifs, tight kerning, mixed scripts — type is part of the visual fabric.
          </p>
          <p style="margin-bottom: var(--space-6);">
            <strong>Analog Memory, Digital Present.</strong> Film grain, paper folds, halftone dots (the analog past) coexist with CRT scanlines, chromatic aberration, pixelation (the digital past). The website is a time-collapse of media history.
          </p>
          <p style="margin-bottom: var(--space-6);">
            <strong>Slow Motion.</strong> Animations are slow (8s+ cycles). Nothing is fast, snappy, or playful. The motion language is breathing, floating, decaying — never bouncing or elastic.
          </p>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={0.5}>
        <div style="margin-top: var(--space-12); padding-top: var(--space-8); border-top: 1px solid rgba(255,255,255,0.06);">
          <p class="meta-text" style="text-align: right; font-family: var(--font-mono);">
            NOISE WEB V2 — JULY 2026
            <br />
            DERIVED FROM 14 REFERENCE IMAGES
          </p>
        </div>
      </ScrollReveal>
    </div>
  </section>
</BaseLayout>

<style>
  .section {
    padding: var(--space-16) clamp(1.5rem, 4vw, 4rem);
    position: relative;
  }

  .section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--gradient-section);
    pointer-events: none;
  }

  .section:first-of-type::before {
    display: none;
  }

  .container {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
  }

  /* Ensure cards in grid maintain stagger on mobile */
  @media (max-width: 768px) {
    .card-grid-stagger {
      grid-template-columns: 1fr;
    }

    .card-grid-stagger .card-stack:nth-child(odd),
    .card-grid-stagger .card-stack:nth-child(even) {
      margin-top: 0;
      margin-bottom: 0;
    }
  }

  /* Paper texture for manifesto section */
  .paper-texture::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='paper'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.04' numOctaves='5'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23paper)' opacity='0.05'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 400px 400px;
    opacity: 0.08;
    mix-blend-mode: multiply;
    z-index: 0;
  }

  .paper-texture > * {
    position: relative;
    z-index: 1;
  }
</style>