---
// Scroll Reveal — IntersectionObserver-based reveal animations
// Respects prefers-reduced-motion, supports stagger delays

interface Props {
  children: any;
  delay?: number;
  threshold?: number;
  rootMargin?: string;
  once?: boolean;
  className?: string;
}

const {
  children,
  delay = 0,
  threshold = 0.1,
  rootMargin = '0px 0px -50px 0px',
  once = true,
  className = '',
} = Astro.props;
---

<div
  class="reveal {className}"
  data-reveal
  data-delay={delay}
  data-threshold={threshold}
  data-root-margin={rootMargin}
  data-once={once}
  role="region"
>
  <slot>{children}</slot>
</div>

<script>
  // Scroll Reveal Intersection Observer - Client-side
  function initScrollReveal(root = document) {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const elements = root.querySelectorAll('[data-reveal]:not(.visible)');

    if (!elements.length) return;

    if (prefersReducedMotion) {
      elements.forEach(el => el.classList.add('visible'));
      return;
    }

    const observerOptions = (el: Element) => ({
      threshold: parseFloat(el.getAttribute('data-threshold') || '0.1'),
      rootMargin: el.getAttribute('data-root-margin') || '0px 0px -50px 0px',
    });

    const observers = new Map<Element, IntersectionObserver>();

    elements.forEach(el => {
      const delay = parseFloat(el.getAttribute('data-delay') || '0');
      const once = el.getAttribute('data-once') !== 'false';

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            setTimeout(() => {
              entry.target.classList.add('visible');
            }, delay * 1000);

            if (once) {
              observer.unobserve(entry.target);
            }
          } else if (!once) {
            entry.target.classList.remove('visible');
          }
        });
      }, observerOptions(el));

      observer.observe(el);
      observers.set(el, observer);
    });

    // Cleanup
    return () => {
      observers.forEach(observer => observer.disconnect());
      observers.clear();
    };
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => initScrollReveal());
  } else {
    initScrollReveal();
  }

  // Re-initialize after Astro View Transitions
  document.addEventListener('astro:after-swap', () => {
    initScrollReveal();
  });

  // Listen for reduced motion changes
  window.matchMedia('(prefers-reduced-motion: reduce)').addEventListener('change', (e) => {
    if (e.matches) {
      document.querySelectorAll('[data-reveal]').forEach(el => {
        el.classList.add('visible');
      });
    }
  });
</script>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(2rem);
    filter: blur(4px);
    will-change: opacity, transform, filter;
  }

  .reveal.visible {
    animation: reveal-up 3s cubic-bezier(0.19, 1, 0.22, 1) forwards;
  }

  @keyframes reveal-up {
    from {
      opacity: 0;
      transform: translateY(2rem);
      filter: blur(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  /* Stagger delays via data attribute */
  .reveal.visible[data-delay="0.1"] { animation-delay: 0.1s; }
  .reveal.visible[data-delay="0.2"] { animation-delay: 0.2s; }
  .reveal.visible[data-delay="0.3"] { animation-delay: 0.3s; }
  .reveal.visible[data-delay="0.4"] { animation-delay: 0.4s; }
  .reveal.visible[data-delay="0.5"] { animation-delay: 0.5s; }
  .reveal.visible[data-delay="0.6"] { animation-delay: 0.6s; }
  .reveal.visible[data-delay="0.7"] { animation-delay: 0.7s; }
  .reveal.visible[data-delay="0.8"] { animation-delay: 0.8s; }
  .reveal.visible[data-delay="0.9"] { animation-delay: 0.9s; }
  .reveal.visible[data-delay="1.0"] { animation-delay: 1.0s; }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .reveal {
      opacity: 1;
      transform: none;
      filter: none;
    }
    .reveal.visible {
      animation: none;
    }
  }
</style>