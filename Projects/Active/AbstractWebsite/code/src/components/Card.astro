---
// Card Component — Printed feel, hard offset shadow, noise overlay
// Variants: default, stack, wide, text-only

interface CardProps {
  variant?: 'default' | 'stack' | 'wide' | 'text-only';
  imageSrc?: string;
  imageAlt?: string;
  badge?: string;
  title: string;
  description?: string;
  href?: string;
  metadata?: Array<{ label: string; value: string }>;
}

const {
  variant = 'default',
  imageSrc,
  imageAlt = '',
  badge = 'PROJECT',
  title = 'Untitled Project',
  description = 'A description of this project or piece of work.',
  href,
  metadata = [],
} = Astro.props;

const cardClasses = ['card', variant !== 'default' && `card--${variant}`].filter(Boolean).join(' ');
const isLink = !!href;
const Tag = isLink ? 'a' : 'article';
---

<{Tag} class={cardClasses} href={href} role={isLink ? 'link' : 'article'} aria-label={isLink ? `View ${title}` : undefined}>
  {imageSrc && variant !== 'text-only' && (
    <div class="card-image" aria-hidden="true">
      <img src={imageSrc} alt={imageAlt} class="card-image-treatment" loading="lazy" />
      <div class="card-image-gradient" aria-hidden="true" />
    </div>
  )}

  <div class="card-content">
    {badge && <span class="card-badge">{badge}</span>}

    <h3 class="card-title">
      {isLink ? <a href={href} class="card-title-link">{title}</a> : title}
    </h3>

    {description && <p class="card-body">{description}</p>}

    {metadata.length > 0 && (
      <dl class="card-meta" role="list">
        {metadata.map((item) => (
          <div class="card-meta-item" role="listitem">
            <dt class="label">{item.label}</dt>
            <dd class="label label-accent" style="font-family: var(--font-mono);">{item.value}</dd>
          </div>
        ))}
      </dl>
    )}
  </div>

  {isLink && (
    <div class="card-hover-indicator" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
    </div>
  )}
</{Tag}>

<style>
  .card {
    position: relative;
    background: var(--color-bg-mid);
    border: 1px solid rgba(255, 255, 255, 0.12);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.4);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }

  /* Noise overlay on card */
  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 256px 256px;
    opacity: 0.08;
    pointer-events: none;
    z-index: 1;
  }

  .card:focus-visible {
    outline: none;
    border-color: var(--color-accent-cyan);
    box-shadow:
      0 0 0 3px rgba(168, 240, 232, 0.2),
      4px 4px 0 rgba(0, 0, 0, 0.4);
  }

  .card--stack {
    /* Stagger handled by parent grid */
  }

  .card--wide {
    grid-column: span 2;
  }

  .card--text-only {
    padding: var(--space-6);
  }

  .card-image {
    position: relative;
    height: 18rem;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.75) contrast(1.15);
    transition: filter 0.4s ease, transform 0.6s ease;
  }

  .card-image-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(10, 22, 40, 0.4) 100%);
    z-index: 1;
  }

  .card-content {
    padding: var(--space-5);
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-badge {
    display: inline-block;
    font-family: var(--font-condensed);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-accent-cyan);
    margin-bottom: var(--space-2);
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    line-height: var(--leading-snug);
    margin-bottom: var(--space-3);
  }

  .card-title-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .card-title-link:hover {
    color: var(--color-accent-cyan);
  }

  .card-body {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    max-width: 65ch;
    flex: 1;
  }

  .card-meta {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: var(--space-3);
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .card-meta-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .card-meta dt {
    font-family: var(--font-condensed);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-ghost);
  }

  .card-meta dd {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent-cyan);
  }

  .card-hover-indicator {
    position: absolute;
    bottom: var(--space-4);
    right: var(--space-4);
    opacity: 0;
    transform: translate(4px, 4px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    color: var(--color-accent-cyan);
    pointer-events: none;
  }

  /* Stack variant stagger */
  .card-stack:nth-child(odd) {
    margin-top: var(--space-6);
  }

  .card-stack:nth-child(even) {
    margin-bottom: var(--space-6);
  }

  /* Hover states */
  @media (hover: hover) {
    .card:hover {
      transform: translate(-2px, -2px);
      box-shadow: 6px 6px 0 rgba(0, 0, 0, 0.5);
    }

    .card:hover .card-image img {
      filter: brightness(0.85) contrast(1.2);
      transform: scale(1.03);
    }

    .card:hover .card-hover-indicator {
      opacity: 1;
      transform: translate(0, 0);
    }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .card-image {
      height: 14rem;
    }

    .card--wide {
      grid-column: auto;
    }
  }
</style>