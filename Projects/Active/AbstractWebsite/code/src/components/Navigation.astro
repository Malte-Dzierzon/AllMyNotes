---
// Navigation Component — Minimal, atmospheric, museum-label feel
// Variants: default (semi-transparent), transparent (hero), inline (content)

interface Props {
  variant?: 'default' | 'transparent' | 'inline';
  brandName?: string;
  links?: Array<{ label: string; href: string }>;
}

const {
  variant = 'default',
  brandName = 'NOISE WEB',
  links = [
    { label: 'WORK', href: '/work' },
    { label: 'ABOUT', href: '/about' },
    { label: 'CONTACT', href: '/contact' },
  ],
} = Astro.props;
---

<nav class="nav nav--{variant}" role="navigation" aria-label="Main navigation">
  <a href="/" class="nav-brand" aria-label="Home">
    {brandName}
  </a>

  <ul class="nav-links" role="menubar">
    {links.map((link) => (
      <li role="none">
        <a href={link.href} class="nav-link" role="menuitem">{link.label}</a>
      </li>
    ))}
  </ul>

  <button
    class="nav-hamburger"
    aria-label="Toggle navigation menu"
    aria-expanded="false"
    aria-controls="mobile-menu"
    data-hamburger
  >
    <span aria-hidden="true"></span>
    <span aria-hidden="true"></span>
    <span aria-hidden="true"></span>
  </button>
</nav>

<!-- Mobile Menu Overlay -->
<div class="nav-mobile-overlay" id="mobile-menu" role="dialog" aria-modal="true" aria-label="Navigation menu" hidden>
  <div class="nav-mobile-header">
    <a href="/" class="nav-brand" aria-label="Home">{brandName}</a>
    <button
      class="nav-hamburger nav-mobile-close"
      aria-label="Close navigation menu"
      data-mobile-close
    >
      <span aria-hidden="true"></span>
      <span aria-hidden="true"></span>
    </button>
  </div>

  <nav class="nav-mobile-links" role="navigation">
    {links.map((link) => (
      <a href={link.href} class="nav-mobile-link">{link.label}</a>
    ))}
    <a href="/contact" class="nav-mobile-cta">
      WORK WITH US
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
    </a>
  </nav>
</div>

<script>
  // Mobile menu toggle
  const hamburger = document.querySelector('[data-hamburger]');
  const mobileClose = document.querySelector('[data-mobile-close]');
  const mobileMenu = document.getElementById('mobile-menu');

  function openMenu() {
    mobileMenu.hidden = false;
    requestAnimationFrame(() => mobileMenu.classList.add('open'));
    hamburger.classList.add('open');
    hamburger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    mobileMenu.classList.remove('open');
    hamburger.classList.remove('open');
    hamburger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    setTimeout(() => { mobileMenu.hidden = true; }, 400);
  }

  hamburger?.addEventListener('click', openMenu);
  mobileClose?.addEventListener('click', closeMenu);

  // Close on link click
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu?.classList.contains('open')) {
      closeMenu();
    }
  });
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: clamp(1rem, 2vw, 1.5rem) clamp(1.5rem, 4vw, 4rem);
  }

  .nav--default {
    background: rgba(10, 22, 40, 0.6);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .nav--transparent {
    background: transparent;
    border-bottom: none;
  }

  .nav--inline {
    position: relative;
    background: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    backdrop-filter: none;
  }

  .nav-brand {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    text-decoration: none;
    letter-spacing: -0.01em;
    position: relative;
    z-index: 101;
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .nav-brand::before {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    background: var(--color-accent-cyan);
    border-radius: 50%;
    vertical-align: middle;
  }

  .nav-links {
    display: flex;
    gap: var(--space-6);
    list-style: none;
  }

  .nav-link {
    font-family: var(--font-condensed);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    color: var(--color-text-muted);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    transition: color 0.3s ease;
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--color-accent-cyan);
    transition: width 0.3s ease;
  }

  .nav-link:hover {
    color: var(--color-accent-cyan);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-link:focus-visible {
    outline: none;
    color: var(--color-accent-cyan);
  }

  .nav-link:focus-visible::after {
    width: 100%;
  }

  .nav-hamburger {
    display: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-text-primary);
    border: none;
    cursor: pointer;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    padding: 0;
    position: relative;
    z-index: 101;
  }

  .nav-hamburger span {
    display: block;
    width: 16px;
    height: 2px;
    background: var(--color-bg-deep);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .nav-hamburger:focus-visible {
    outline: 2px solid var(--color-accent-cyan);
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .nav-hamburger {
      display: flex;
    }

    .nav-links {
      display: none;
    }

    .nav-hamburger.open span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .nav-hamburger.open span:nth-child(2) {
      opacity: 0;
    }

    .nav-hamburger.open span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }

  /* Mobile Menu Overlay */
  .nav-mobile-overlay {
    position: fixed;
    inset: 0;
    z-index: 99;
    background: var(--color-text-primary);
    display: flex;
    flex-direction: column;
    padding: var(--space-10) clamp(1.5rem, 4vw, 4rem);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s ease;
  }

  .nav-mobile-overlay.open {
    opacity: 1;
    visibility: visible;
  }

  .nav-mobile-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-6);
  }

  .nav-mobile-close {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-bg-deep);
    border: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    padding: 0;
  }

  .nav-mobile-close span {
    display: block;
    width: 16px;
    height: 2px;
    background: var(--color-text-primary);
  }

  .nav-mobile-close span:nth-child(1) {
    transform: rotate(45deg);
  }

  .nav-mobile-close span:nth-child(2) {
    transform: rotate(-45deg);
  }

  .nav-mobile-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-top: var(--space-10);
    flex: 1;
  }

  .nav-mobile-link {
    font-family: var(--font-sans);
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    color: var(--color-bg-deep);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    transition: color 0.3s ease;
  }

  .nav-mobile-link:hover {
    color: var(--color-accent-cyan);
  }

  .nav-mobile-cta {
    margin-top: auto;
    color: var(--color-accent-glitch-magenta);
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    text-decoration: none;
  }

  .nav-mobile-cta svg {
    flex-shrink: 0;
  }
</style>