---
// Footer — Minimal archival footer with metadata feel

interface FooterProps {
  brandName?: string;
  links?: Array<{ label: string; href: string }>;
  copyright?: string;
  meta?: Array<{ label: string; value: string }>;
}

const {
  brandName = 'NOISE WEB',
  links = [
    { label: 'WORK', href: '/work' },
    { label: 'ABOUT', href: '/about' },
    { label: 'CONTACT', href: '/contact' },
    { label: 'ARCHIVE', href: '/archive' },
  ],
  copyright = '© 2024 NOISE WEB. All rights reserved.',
  meta = [
    { label: 'BUILT WITH', value: 'ASTRO + TAILWIND' },
    { label: 'FONTS', value: 'INTER, CRIMSON TEXT, JETBRAINS MONO' },
    { label: 'DESIGN SYSTEM', value: 'NOISE WEB V2' },
  ],
} = Astro.props;
---

<footer class="footer" role="contentinfo">
  <div class="footer-brand">
    <a href="/" class="footer-brand-link" aria-label="Home">
      {brandName}
    </a>
    <p class="footer-tagline">Digital ruins. Analog dreams.</p>
  </div>

  <nav class="footer-nav" aria-label="Footer navigation">
    <ul class="footer-nav-list" role="list">
      {links.map((link) => (
        <li><a href={link.href} class="footer-nav-link">{link.label}</a></li>
      ))}
    </ul>
  </nav>

  <div class="footer-meta" role="contentinfo">
    {meta.map((item) => (
      <div class="footer-meta-item">
        <span class="footer-meta-label">{item.label}</span>
        <span class="footer-meta-value">{item.value}</span>
      </div>
    ))}
  </div>

  <div class="footer-bottom">
    <p class="footer-copyright">{copyright}</p>
    <p class="footer-meta-code">
      <span class="label" style="font-family: var(--font-mono); font-size: var(--text-xs);">Nº</span>
      <span style="font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-text-ghost);">067</span>
      <span style="margin: 0 var(--space-3);" class="label" style="font-family: var(--font-mono); font-size: var(--text-xs);">VER</span>
      <span style="font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-text-ghost);">2.0.0</span>
    </p>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-10) clamp(1.5rem, 4vw, 4rem);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--space-8);
  }

  .footer-brand {
    grid-column: 1 / -1;
    padding-bottom: var(--space-6);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .footer-brand-link {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    text-decoration: none;
    letter-spacing: -0.01em;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }

  .footer-brand-link::before {
    content: '';
    display: inline-block;
    width: 8px;
    height: 8px;
    background: var(--color-accent-cyan);
    border-radius: 50%;
  }

  .footer-tagline {
    font-family: var(--font-condensed);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-transform: lowercase;
    letter-spacing: var(--tracking-wide);
  }

  .footer-nav-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .footer-nav-link {
    font-family: var(--font-condensed);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer-nav-link:hover {
    color: var(--color-accent-cyan);
  }

  .footer-nav-link:focus-visible {
    outline: none;
    color: var(--color-accent-cyan);
  }

  .footer-meta {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: var(--space-4);
    margin-top: var(--space-4);
  }

  .footer-meta-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .footer-meta-label {
    font-family: var(--font-condensed);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-ghost);
  }

  .footer-meta-value {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent-cyan);
  }

  .footer-bottom {
    grid-column: 1 / -1;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: var(--space-8);
    margin-top: var(--space-6);
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .footer-copyright {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-ghost);
  }

  .footer-meta-code {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-ghost);
  }
</style>