---
// Section Divider — Atmospheric section transitions without aggressive visual breaks

interface Props {
  label?: string;
  position?: 'left' | 'center' | 'right';
  variant?: 'default' | 'minimal' | 'labeled';
}

const {
  label = 'SECTION',
  position = 'left',
  variant = 'default',
} = Astro.props;
---

<div class="section-divider section-divider--{position} section-divider--{variant}" role="separator" aria-label={label}>
  {position !== 'right' && <span class="section-divider-line" aria-hidden="true" />}
  {label && variant !== 'minimal' && <span class="section-divider-label">{label}</span>}
  {position !== 'left' && <span class="section-divider-line" aria-hidden="true" />}
</div>

<style>
  .section-divider {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) 0;
  }

  .section-divider--left {
    justify-content: flex-start;
  }

  .section-divider--center {
    justify-content: center;
  }

  .section-divider--right {
    justify-content: flex-end;
  }

  .section-divider--minimal {
    gap: 0;
    padding: var(--space-2) 0;
  }

  .section-divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.1) 50%,
      transparent 100%
    );
    min-width: 60px;
  }

  .section-divider-label {
    font-family: var(--font-condensed);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-ghost);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .section-divider--center .section-divider-label {
    margin: 0 var(--space-4);
  }

  .section-divider--labeled .section-divider-line {
    flex: 1;
  }
</style>