---
// Hero Section Components — Multiple Patterns from Design System V2
// Pattern A: Collage (Full-screen with text/image split)
// Pattern B: Diagonal Split (Dramatic diagonal division)
// Pattern C: Split Screen Code/Visual
// Pattern D: Typographic Composition
// Pattern E: Vertical Stack

interface HeroProps {
  pattern?: 'collage' | 'diagonal' | 'split' | 'typographic' | 'stack';
  title?: string;
  subtitle?: string;
  description?: string;
  ctaText?: string;
  ctaHref?: string;
  imageSrc?: string;
  imageAlt?: string;
  codeContent?: string;
  visualContent?: string;
}

const {
  pattern = 'collage',
  title = 'NOISE WEB',
  subtitle = 'DIGITAL RUINS / ANALOG MEMORY',
  description = 'A digital exhibition space where memory and technology decay together. Quiet, melancholic, atmospheric.',
  ctaText = 'ENTER EXHIBITION',
  ctaHref = '/exhibition',
  imageSrc = 'https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=1920&q=80',
  imageAlt = 'Abstract digital texture',
  codeContent = `// Generative noise field
const noise = new PerlinNoise();
const field = [];

for (let y = 0; y < height; y++) {
  for (let x = 0; x < width; x++) {
    const n = noise.noise3D(x * 0.01, y * 0.01, time * 0.1);
    field[y][x] = map(n, -1, 1, 0, 255);
  }
}

render(field);`,
  visualContent = '',
} = Astro.props;
---

<header class="hero hero--{pattern}" role="banner">
  {pattern === 'collage' && (
    <div class="hero-collage">
      <div class="hero-collage-bg">
        <img src={imageSrc} alt={imageAlt} class="hero-image-treatment" />
        <div class="hero-vignette" />
        <div class="scanlines scanlines-blue" aria-hidden="true" />
        <div class="chromatic-overlay" aria-hidden="true" />
      </div>

      <div class="hero-collage-content hero-collage-content-left">
        <div class="hero-badge">
          <span class="label label-accent">EXHIBITION 01</span>
          <span class="label" style="color: var(--color-text-ghost); margin-left: var(--space-3);">NOW SHOWING</span>
        </div>

        <h1 class="hero-heading chromatic-overlay" data-text={title}>
          {title}
        </h1>

        <p class="poetic-text" style="margin-top: var(--space-6); margin-bottom: var(--space-8); max-width: 35ch;">
          {description}
        </p>

        <a href={ctaHref} class="button button-primary">
          {ctaText}
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
        </a>
      </div>

      <div class="hero-collage-content hero-collage-content-right">
        <div class="hero-overlay-text">
          <span class="label label-accent" style="writing-mode: vertical-rl; text-orientation: mixed;">SCROLL</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-top: var(--space-4);" aria-hidden="true"><path d="M12 5v14M19 12l-7 7-7-7"/></svg>
        </div>
      </div>

      <div class="scroll-indicator" aria-hidden="true">
        <div class="scroll-line" />
        <span class="scroll-text">SCROLL</span>
      </div>
    </div>
  )}

  {pattern === 'diagonal' && (
    <div class="hero-diagonal">
      <div class="hero-diagonal-light" aria-hidden="true" />
      <div class="hero-diagonal-content">
        <div class="hero-diagonal-content-dark">
          <div class="hero-badge">
            <span class="label label-accent">PATTERN B</span>
            <span class="label" style="color: var(--color-text-ghost); margin-left: var(--space-3);">DIAGONAL SPLIT</span>
          </div>
          <h1 class="hero-heading" data-text={title}>{title}</h1>
          <p class="poetic-text" style="margin-top: var(--space-6); max-width: 40ch;">{description}</p>
          <a href={ctaHref} class="button button-primary" style="margin-top: var(--space-8);">{ctaText}</a>
        </div>
        <div class="hero-diagonal-content-light">
          <div class="diagonal-visual">
            <img src={imageSrc} alt={imageAlt} class="hero-image-treatment" />
            <div class="scanlines scanlines-subtle" aria-hidden="true" />
          </div>
          <div class="diagonal-meta">
            <p class="label label-accent">01 / 05</p>
            <p class="meta-text">COMPOSITION IN ASYMMETRY</p>
          </div>
        </div>
      </div>
    </div>
  )}

  {pattern === 'split' && (
    <div class="hero-split">
      <div class="hero-split-code" role="img" aria-label="Generative noise field code">
        <div class="code-header">
          <span class="label label-accent">GENERATIVE</span>
          <span class="label" style="color: var(--color-text-ghost);">NOISE_FIELD_v3.js</span>
        </div>
        <pre><code>{codeContent}</code></pre>
        <div class="scanlines" aria-hidden="true" />
      </div>
      <div class="hero-split-visual">
        {visualContent ? (
          <div class="visual-output" style="background-image: url({visualContent});" aria-hidden="true" />
        ) : (
          <img src={imageSrc} alt={imageAlt} class="hero-image-treatment" />
        )}
        <div class="chromatic-overlay" aria-hidden="true" />
      </div>
    </div>
  )}

  {pattern === 'typographic' && (
    <section class="hero-typographic" aria-labelledby="typo-title">
      <div class="hero-typographic-bg" aria-hidden="true">
        <div class="paper-texture" />
        <div class="fold-line-horizontal" style="top: 40%;" />
        <div class="fold-line-horizontal" style="bottom: 40%;" />
        <div class="halftone-overlay" style="opacity: 0.04;" />
      </div>

      <div class="hero-typographic-content" id="typo-title">
        <div class="typo-word-group">
          <span class="hero-typographic-word" data-text="NOISE">NOISE</span>
          <span class="hero-typographic-blur" data-text="NOISE">NOISE</span>
        </div>
        <div class="typo-word-group">
          <span class="hero-typographic-word" data-text="WEB">WEB</span>
          <span class="hero-typographic-blur" data-text="WEB">WEB</span>
        </div>
        <p class="hero-typographic-sub">digital ruins / analog memory</p>
        <p class="hero-typographic-sub" style="margin-top: var(--space-2);">Nº 001 — 2024</p>
        <div style="margin-top: var(--space-10);">
          <a href={ctaHref} class="button button-glitch">{ctaText}</a>
        </div>
      </div>

      <div class="scroll-indicator" aria-hidden="true">
        <div class="scroll-line" />
        <span class="scroll-text">SCROLL</span>
      </div>
    </section>
  )}

  {pattern === 'stack' && (
    <section class="hero-stack" aria-labelledby="stack-title">
      <div class="hero-stack-content" id="stack-title">
        <div class="hero-badge">
          <span class="label label-accent">PATTERN E</span>
          <span class="label" style="color: var(--color-text-ghost); margin-left: var(--space-3);">VERTICAL STACK</span>
        </div>
        <h1 class="hero-heading">{title}</h1>
        <p class="poetic-text" style="margin-top: var(--space-6); margin-bottom: var(--space-8); max-width: 40ch;">{description}</p>
        <a href={ctaHref} class="button button-primary">{ctaText}</a>
      </div>

      <div class="hero-stack-visual" aria-hidden="true">
        <div class="hero-stack-item">
          <img src={imageSrc} alt="" class="hero-image-treatment" />
        </div>
        <div class="hero-stack-item">
          <img src="https://images.unsplash.com/photo-1635070041078-e363dbe005cb?w=1920&q=80" alt="" class="hero-image-treatment" />
        </div>
        <div class="hero-stack-item">
          <img src="https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=1920&q=80" alt="" class="hero-image-treatment" />
        </div>
      </div>

      <div class="scroll-indicator" aria-hidden="true">
        <div class="scroll-line" />
        <span class="scroll-text">SCROLL</span>
      </div>
    </section>
  )}
</header>

<style>
  /* Base Hero Styles */
  .hero {
    position: relative;
    isolation: isolate;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--gradient-vignette);
    pointer-events: none;
    z-index: 1;
  }

  /* Scroll Indicator */
  .scroll-indicator {
    position: absolute;
    bottom: var(--space-6);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    z-index: 10;
    opacity: 0.5;
    animation: scroll-bounce 3s ease-in-out infinite;
  }

  @keyframes scroll-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(8px); }
  }

  .scroll-line {
    width: 1px;
    height: 40px;
    background: linear-gradient(180deg, var(--color-accent-cyan) 0%, transparent 100%);
  }

  .scroll-text {
    font-family: var(--font-condensed);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-text-ghost);
  }

  /* Hero Badge */
  .hero-badge {
    display: flex;
    align-items: center;
    margin-bottom: var(--space-4);
  }

  /* Pattern A — Collage */
  .hero-collage {
    position: relative;
    min-height: 100vh;
    display: grid;
    grid-template-columns: var(--split-60-40);
    align-items: center;
    overflow: hidden;
  }

  .hero-collage-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-collage-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background: var(--gradient-vignette);
    pointer-events: none;
  }

  .hero-collage-content {
    position: relative;
    z-index: 2;
    padding: var(--space-10);
  }

  .hero-collage-content-left {
    max-width: 600px;
  }

  .hero-collage-content-right {
    position: relative;
    z-index: 2;
    padding: var(--space-10);
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  .hero-overlay-text {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-2);
  }

  .hero-overlay-text .label {
    writing-mode: vertical-rl;
    text-orientation: mixed;
  }

  /* Pattern B — Diagonal Split */
  .hero-diagonal {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
  }

  .hero-diagonal::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--color-bg-deep);
    clip-path: polygon(0 0, 45% 0, 25% 100%, 0 100%);
    z-index: 0;
  }

  .hero-diagonal-light {
    position: absolute;
    inset: 0;
    background: var(--color-bg-mid);
    clip-path: polygon(45% 0, 100% 0, 100% 100%, 25% 100%);
    z-index: 0;
  }

  .hero-diagonal-content {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 45% 55%;
    min-height: 100vh;
    align-items: center;
  }

  .hero-diagonal-content-dark,
  .hero-diagonal-content-light {
    padding: var(--space-10);
  }

  .hero-diagonal-content-light {
    color: var(--color-text-secondary);
  }

  .diagonal-visual {
    position: relative;
    height: 70vh;
    overflow: hidden;
  }

  .diagonal-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.7) contrast(1.2);
  }

  .diagonal-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-top: var(--space-6);
    padding-right: var(--space-10);
  }

  /* Pattern C — Split Screen */
  .hero-split {
    display: grid;
    grid-template-columns: var(--split-data);
    min-height: 80vh;
  }

  .hero-split-code {
    background: var(--color-bg-deep);
    padding: var(--space-8);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: var(--leading-mono);
    color: var(--color-text-muted);
    overflow-x: auto;
    white-space: pre;
    position: relative;
  }

  .hero-split-code pre {
    margin: 0;
  }

  .hero-split-code code {
    font-family: inherit;
    font-size: inherit;
    line-height: inherit;
  }

  .code-header {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .hero-split-code .keyword { color: var(--color-accent-cyan-dim); }
  .hero-split-code .string { color: var(--color-accent-glitch-magenta); }
  .hero-split-code .comment { color: rgba(138, 169, 196, 0.5); }
  .hero-split-code .function { color: var(--color-accent-blue); }
  .hero-split-code .number { color: var(--color-accent-warm); }

  .visual-output {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    filter: brightness(0.65) contrast(1.3) saturate(0.85);
  }

  /* Pattern D — Typographic Composition */
  .hero-typographic {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    background: var(--color-bg-parchment);
    overflow: hidden;
  }

  .hero-typographic-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-typographic-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: var(--space-8);
  }

  .typo-word-group {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-2);
  }

  .hero-typographic-word {
    font-family: var(--font-sans);
    font-weight: var(--weight-black);
    font-size: var(--text-3xl);
    text-transform: lowercase;
    color: var(--color-bg-deep);
    line-height: 0.9;
  }

  .hero-typographic-blur {
    font-size: var(--text-3xl);
    font-weight: var(--weight-black);
    filter: blur(6px);
    opacity: 0.6;
    mix-blend-mode: multiply;
    color: var(--color-accent-cyan);
    position: absolute;
    top: 0;
    left: 0;
  }

  .typo-word-group {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .hero-typographic-sub {
    font-family: var(--font-condensed);
    font-size: var(--text-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: lowercase;
    color: var(--color-text-ghost);
    margin-top: var(--space-6);
  }

  /* Pattern E — Vertical Stack */
  .hero-stack {
    display: grid;
    grid-template-columns: var(--split-60-40);
    min-height: 100vh;
  }

  .hero-stack-content {
    padding: var(--space-10);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-stack-visual {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .hero-stack-item {
    flex: 1;
    overflow: hidden;
    position: relative;
    min-height: 33.33vh;
  }

  .hero-stack-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.7) contrast(1.2);
    transition: filter 0.5s ease;
  }

  .hero-stack-item:hover img {
    filter: brightness(0.85) contrast(1.3);
  }

  /* Buttons */
  .button {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-condensed);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.75rem 1.5rem;
    background: transparent;
    border: 2px solid var(--color-text-primary);
    color: var(--color-text-primary);
    cursor: pointer;
    transition: all 0.25s ease;
    position: relative;
  }

  .button:focus-visible {
    outline: none;
    border-color: var(--color-accent-cyan);
    box-shadow: 0 0 0 3px rgba(168, 240, 232, 0.2);
  }

  .button-primary {
    background: var(--color-accent-cyan);
    border-color: var(--color-accent-cyan);
    color: var(--color-bg-deep);
  }

  @media (hover: hover) {
    .button-primary:hover {
      background: transparent;
      color: var(--color-accent-cyan);
      box-shadow: 4px 4px 0 var(--color-accent-cyan);
      transform: translate(-2px, -2px);
    }
  }

  .button-glitch {
    border-color: rgba(208, 96, 192, 0.4);
    color: var(--color-accent-glitch-magenta);
    text-shadow:
      -0.5px 0 var(--color-accent-glitch-cyan),
       0.5px 0 var(--color-accent-glitch-magenta);
  }

  @media (hover: hover) {
    .button-glitch:hover {
      background: rgba(208, 96, 192, 0.1);
      border-color: var(--color-accent-glitch-magenta);
      box-shadow:
         3px 0 0 rgba(96, 208, 208, 0.3),
        -3px 0 0 rgba(208, 96, 192, 0.3);
      transform: translate(-2px, -2px);
    }
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .hero-collage,
    .hero-diagonal-content,
    .hero-split,
    .hero-stack {
      grid-template-columns: 1fr;
    }

    .hero-diagonal::before,
    .hero-diagonal-light {
      clip-path: none;
      background: var(--color-bg-dark);
    }

    .hero-diagonal-light {
      display: none;
    }

    .hero-stack-visual {
      display: none;
    }

    .hero-split-code {
      max-height: 40vh;
    }
  }

  @media (max-width: 768px) {
    :root {
      --text-3xl: clamp(2rem, 8vw, 3.5rem);
    }

    .hero-typographic-word,
    .hero-typographic-blur {
      font-size: var(--text-2xl);
    }

    .diagonal-meta {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-2);
    }
  }
</style>