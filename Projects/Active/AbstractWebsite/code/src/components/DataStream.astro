---
// Data Stream Block — Code/data display with CRT scanlines
// Reference: Image 6 (Mandelbrot fractal split-screen)

interface Props {
  title?: string;
  language?: string;
  content: string;
  copyable?: boolean;
}

const {
  title = 'DATA_STREAM',
  language = 'text',
  content,
  copyable = true,
} = Astro.props;
---

<div class="data-stream-container" role="region" aria-label={title}>
  <div class="data-stream-header">
    <span class="label label-accent">{title}</span>
    {copyable && (
      <button class="data-stream-copy button button-ghost" aria-label="Copy to clipboard" data-copy-target={title}>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>
        COPY
      </button>
    )}
  </div>

  <pre class="data-stream" role="code" aria-label={`Code content for ${title}`} data-language={language}>
    <code class="language-{language}">{content.trim()}</code>
  </pre>
</div>

<script>
  // Copy to clipboard functionality
  document.querySelectorAll('.data-stream-copy').forEach(btn => {
    btn.addEventListener('click', async () => {
      const targetId = btn.dataset.copyTarget;
      const codeBlock = btn.closest('.data-stream-container')?.querySelector('code');
      if (codeBlock) {
        try {
          await navigator.clipboard.writeText(codeBlock.textContent || '');
          const originalText = btn.textContent;
          btn.textContent = 'COPIED';
          btn.classList.add('copied');
          setTimeout(() => {
            btn.textContent = originalText;
            btn.classList.remove('copied');
          }, 2000);
        } catch (e) {
          console.warn('Copy failed:', e);
        }
      }
    });
  });
</script>

<style>
  .data-stream-container {
    position: relative;
  }

  .data-stream-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .data-stream-copy {
    font-size: var(--text-xs);
    padding: 0.25rem 0.75rem;
  }

  .data-stream-copy:hover {
    color: var(--color-accent-cyan);
  }

  .data-stream-copy.copied {
    color: var(--color-success);
  }

  .data-stream {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: var(--leading-mono);
    color: var(--color-text-muted);
    white-space: pre-wrap;
    overflow-x: auto;
    max-height: 500px;
    overflow-y: auto;
    position: relative;
    padding: var(--space-4);
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.06);
    tab-size: 2;
  }

  .data-stream::after {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      to bottom,
      transparent 0px,
      rgba(0, 0, 0, 0.06) 1px,
      transparent 2px
    );
    background-size: 100% 3px;
    pointer-events: none;
    z-index: 1;
  }

  .data-stream code {
    font-family: inherit;
    font-size: inherit;
    line-height: inherit;
    color: inherit;
    position: relative;
    z-index: 2;
    display: block;
  }

  /* Syntax highlighting tokens (basic) */
  .data-stream .comment { color: rgba(138, 169, 196, 0.5); font-style: italic; }
  .data-stream .keyword { color: var(--color-accent-cyan-dim); }
  .data-stream .string { color: var(--color-accent-glitch-magenta); }
  .data-stream .number { color: var(--color-accent-warm); }
  .data-stream .function { color: var(--color-accent-blue); }
  .data-stream .operator { color: var(--color-text-muted); }
  .data-stream .punctuation { color: var(--color-text-ghost); }
  .data-stream .property { color: var(--color-accent-cyan); }
  .data-stream .selector { color: var(--color-accent-glitch-cyan); }

  /* Scrollbar styling for data stream */
  .data-stream::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }

  .data-stream::-webkit-scrollbar-track {
    background: transparent;
  }

  .data-stream::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 3px;
  }

  .data-stream::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .data-stream {
      font-size: 0.625rem; /* 10px */
      max-height: 300px;
      padding: var(--space-3);
    }
  }
</style>